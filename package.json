{
  "name": "gulp-template",
  "version": "1.0.0",
  "description": "My gulp template",
  "main": "gulpfile.js",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation NODE_ENV=development gulp dev",
    "build:dev": "cross-env NODE_OPTIONS=--no-deprecation NODE_ENV=production gulp build",
    "build:prod": "cross-env NODE_OPTIONS=--no-deprecation NODE_ENV=production gulp build-min",
    "tailwind:setup": "node .template/setup/tailwind/setup.js",
    "preview": "pnpm build:prod && gulp start",
    "lint": "eslint . && stylelint \"src/**/*.{css,scss}\"",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.{css,scss}\" --fix",
    "format": "prettier --write .",
    "clean": "rimraf dist && rimraf node_modules"
  },
  "author": "Darkoto",
  "license": "ISC",
  "devDependencies": {
    "@darkoto/gulp-template-cli": "^1.0.2",
    "@eslint/js": "^10.0.1",
    "browser-sync": "^2.29.3",
    "cross-env": "^10.1.0",
    "del": "^7.1.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "gulp": "^4.0.2",
    "gulp-autoprefixer": "^9.0.0",
    "gulp-avif-webp-html-universal": "^0.1.3",
    "gulp-cssmin": "^0.2.0",
    "gulp-esbuild": "^0.14.1",
    "gulp-favicons": "^4.0.2",
    "gulp-file-include": "^2.3.0",
    "gulp-fonter": "^0.3.0",
    "gulp-group-css-media-queries": "^1.2.2",
    "gulp-header": "^2.0.12",
    "gulp-htmlmin": "^5.0.1",
    "gulp-if": "^3.0.0",
    "gulp-jsmin": "^0.1.5",
    "gulp-newer": "^1.4.0",
    "gulp-notify": "^4.0.0",
    "gulp-plumber": "^1.2.1",
    "gulp-prettify": "^0.5.0",
    "gulp-replace": "^1.1.4",
    "gulp-sass": "^6.0.1",
    "gulp-sass-glob-use-forward": "^0.1.3",
    "gulp-svg-sprite": "^2.0.3",
    "gulp-ttf2woff2": "^4.0.1",
    "gulp-web-images-css": "^1.3.1",
    "gulp-zip": "^6.1.0",
    "node-notifier": "^10.0.1",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.10",
    "sass": "^1.100.0",
    "sharp": "^0.33.0",
    "stylelint": "^17.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tailwindcss": "3.4.17"
  }
}
